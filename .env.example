# Frontend only
# .env.local에는 아래 두 값만 넣으세요.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_NAVER_AUTH_URL=

# Render backend only
# 아래 값들은 Vercel 프론트 환경변수나 .env.local에 넣지 마세요.
PUBLIC_SITE_URL=https://romantichamilton.store
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Render가 PORT를 자동 주입합니다. 로컬 백엔드 테스트 때만 사용하세요.
PORT=3000
